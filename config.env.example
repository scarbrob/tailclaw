#!/usr/bin/env bash
# tailclaw config — copy to config.env and fill in your values

# =============================================================================
# Azure
# =============================================================================
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-openclaw
AZURE_LOCATION=westus2
AZURE_VM_NAME=vm-openclaw
AZURE_VM_SIZE=Standard_B2s
AZURE_ADMIN_USER=clawadmin
AZURE_AUTO_SHUTDOWN_TIME=0200       # 24h format, UTC

# =============================================================================
# Tailscale
# Leave TAILSCALE_AUTH_KEY blank for interactive auth (you'll visit a URL)
# Or generate a pre-auth key at https://login.tailscale.com/admin/settings/keys
# =============================================================================
TAILSCALE_AUTH_KEY=

# =============================================================================
# OpenClaw
# OPENCLAW_GATEWAY_TOKEN is auto-generated (48 hex chars) if left blank
# =============================================================================
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_PERSONALITY="Detail oriented, no bullshit, challenges your thinking, offers different perspectives"

# =============================================================================
# Discord
# Create a bot at https://discord.com/developers/applications
# Required intents: Message Content, Server Members, Presence
# =============================================================================
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ROLE_ID=
DISCORD_DM_ALLOW_USER_IDS=         # comma-separated Discord user IDs

# =============================================================================
# AI Models
# Option 1: GitHub Copilot (interactive device flow auth via script 09)
# Option 2: Set ANTHROPIC_API_KEY or OPENAI_API_KEY and configure via openclaw onboard
# =============================================================================
GITHUB_COPILOT_ENABLED=false
OPENCLAW_DEFAULT_MODEL=
